{
  "name": "atividade-prisma-orm",
  "version": "1.0.0",
  "description": "Atividade 1 - Prisma ORM - Desenvolvimento Web III",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc -p tsconfig.json",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "dev": "npm run build:frontend && ts-node-dev --respawn src/server.ts",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "nodemon": "^3.1.7",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
