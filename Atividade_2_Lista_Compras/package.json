    "@types/node": "^22.10.2",
    "@types/mongoose": "^5.11.97",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "type": "commonjs",
  "types": "./dist/server.d.ts"
